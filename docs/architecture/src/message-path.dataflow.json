{
  "schema_version": 1,
  "diagram_type": "dataflow",
  "meta": {
    "title": "Message Data Path",
    "subtitle": "From source mailbox to destination without local storage",
    "output": "message-path-dataflow.html",
    "viewBox": [1080, 720]
  },
  "stages": [
    { "label": "Source" },
    { "label": "Read" },
    { "label": "Decide" },
    { "label": "Write" },
    { "label": "Observe" }
  ],
  "nodes": [
    {
      "id": "mbox1",
      "type": "cloud",
      "label": "Host1 folders",
      "sublabel": "IMAP mailbox",
      "stage": 0,
      "row": 1,
      "tag": "source of truth"
    },
    {
      "id": "headers",
      "type": "backend",
      "label": "Header FETCH",
      "sublabel": "UID + flags",
      "stage": 1,
      "row": 0,
      "tag": "identity only"
    },
    {
      "id": "body",
      "type": "backend",
      "label": "Body FETCH",
      "sublabel": "full RFC822",
      "stage": 1,
      "row": 2,
      "tag": "on demand"
    },
    {
      "id": "keys",
      "type": "security",
      "label": "Identity keys",
      "sublabel": "Message-Id…",
      "stage": 2,
      "row": 0,
      "tag": "no secrets"
    },
    {
      "id": "set2",
      "type": "database",
      "label": "Host2 key set",
      "sublabel": "in-memory",
      "stage": 2,
      "row": 2,
      "tag": "stateless"
    },
    {
      "id": "append",
      "type": "cloud",
      "label": "Host2 APPEND",
      "sublabel": "flags + date",
      "stage": 3,
      "row": 1,
      "tag": "destination"
    },
    {
      "id": "stats",
      "type": "messagebus",
      "label": "Counters",
      "sublabel": "xfer/skip/fail",
      "stage": 4,
      "row": 1,
      "tag": "summary"
    }
  ],
  "flows": [
    {
      "from": "mbox1",
      "to": "headers",
      "label": "header literals",
      "classification": "non-body",
      "variant": "emphasis"
    },
    {
      "from": "mbox1",
      "to": "body",
      "label": "full message",
      "classification": "mail payload",
      "variant": "dashed"
    },
    {
      "from": "headers",
      "to": "keys",
      "label": "normalize headers",
      "classification": "identity",
      "variant": "security"
    },
    {
      "from": "headers",
      "to": "set2",
      "label": "build dst keys",
      "classification": "compare",
      "variant": "default"
    },
    {
      "from": "keys",
      "to": "set2",
      "label": "membership check",
      "classification": "dedup",
      "variant": "security"
    },
    {
      "from": "body",
      "to": "append",
      "label": "RFC822 stream",
      "classification": "mail payload",
      "variant": "emphasis"
    },
    {
      "from": "append",
      "to": "stats",
      "label": "outcome",
      "classification": "metrics",
      "variant": "dashed"
    },
    {
      "from": "set2",
      "to": "stats",
      "label": "skipped",
      "classification": "metrics",
      "variant": "dashed"
    }
  ],
  "cards": [
    {
      "dot": "emerald",
      "title": "Stateless design",
      "items": [
        "No local oldmail DB (unlike go-getmail)",
        "Identity rebuilt each run from IMAP state",
        "Safe to interrupt and resume"
      ]
    },
    {
      "dot": "rose",
      "title": "Privacy",
      "items": [
        "Passwords never enter identity keys",
        "Logs redact credentials",
        "Optional --logfile stays local"
      ]
    }
  ]
}
